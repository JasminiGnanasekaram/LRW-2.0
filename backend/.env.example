# Copy to .env and update values
MONGO_URI=mongodb://localhost:27017
DB_NAME=lrw
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=1440
UPLOAD_DIR=./uploads
CORS_ORIGINS=http://localhost:5173

# Whisper audio model size: tiny | base | small | medium | large-v3
WHISPER_MODEL=base

# Celery (optional async processing)
REDIS_URL=redis://localhost:6379/0
USE_CELERY=false

# SMTP for email verification (leave blank to skip sending in dev — links print to console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@lrw.local
APP_BASE_URL=http://localhost:5173
